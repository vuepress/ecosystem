{
  "name": "@vuepress/plugin-meilisearch",
  "version": "2.0.0-rc.125",
  "description": "VuePress plugin - built-in meilisearch",
  "keywords": [
    "meilisearch",
    "plugin",
    "search",
    "vuepress",
    "vuepress-plugin"
  ],
  "homepage": "https://ecosystem.vuejs.press/plugins/search/meilisearch.html",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": "JQiue, Mister-Hope",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "plugins/search/plugin-meilisearch"
  },
  "bin": {
    "vp-meilisearch-scrapper": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/client/styles/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./cli": "./dist/cli/generateScraperConfig.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf --glob ./dist",
    "style": "sass src:dist --embed-sources --style=compressed --pkg-importer=node"
  },
  "dependencies": {
    "@vuepress/helper": "workspace:*",
    "commander": "^14.0.3",
    "meilisearch": "0.55.0",
    "meilisearch-docsearch": "^0.8.0",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vuepress": "catalog:"
  }
}
