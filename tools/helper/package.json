{
  "name": "@vuepress/helper",
  "version": "2.0.0-rc.128",
  "description": "VuePress helper",
  "keywords": [
    "bundler-helper",
    "excerpt",
    "helper",
    "vuepress"
  ],
  "homepage": "https://ecosystem.vuejs.press/tools/helper/",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "tools/helper"
  },
  "files": [
    "dist",
    "scss"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/**/*.css",
    "./scss/**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "sass": "./scss/helper.scss",
      "default": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./noopComponent": {
      "types": "./dist/client/noopComponent.d.ts",
      "default": "./dist/client/noopComponent.js"
    },
    "./noopModule": {
      "types": "./dist/client/noopModule.d.ts",
      "default": "./dist/client/noopModule.js"
    },
    "./colors.css": "./dist/client/styles/colors.css",
    "./message.css": "./dist/client/styles/message.css",
    "./normalize.css": "./dist/client/styles/normalize.css",
    "./sr-only.css": "./dist/client/styles/sr-only.css",
    "./transition/*.css": "./dist/client/styles/transition/*.css",
    "./scss/color": {
      "sass": "./scss/functions/_color.scss"
    },
    "./scss/svg": {
      "sass": "./scss/functions/_svg.scss"
    },
    "./scss/*.scss": "./scss/*.scss",
    "./scss/*": {
      "sass": "./scss/*.scss"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf ./dist"
  },
  "dependencies": {
    "@vue/shared": "^3.5.31",
    "@vueuse/core": "catalog:",
    "cheerio": "^1.2.0",
    "fflate": "^0.8.2",
    "gray-matter": "^4.0.3",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@types/connect": "3.4.38",
    "@vuepress/bundler-vite": "catalog:",
    "@vuepress/bundler-webpack": "catalog:",
    "domhandler": "6.0.1",
    "vite": "8.0.3"
  },
  "peerDependencies": {
    "@vuepress/bundler-vite": "catalog:",
    "@vuepress/bundler-webpack": "catalog:",
    "vuepress": "catalog:"
  },
  "peerDependenciesMeta": {
    "@vuepress/bundler-vite": {
      "optional": true
    },
    "@vuepress/bundler-webpack": {
      "optional": true
    }
  }
}
