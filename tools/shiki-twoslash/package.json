{
  "name": "@vuepress/shiki-twoslash",
  "version": "2.0.0-rc.124",
  "description": "VuePress shiki twoslash",
  "keywords": [
    "shiki",
    "twoslash",
    "vuepress"
  ],
  "homepage": "https://ecosystem.vuejs.press/tools/shiki-twoslash/",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": {
    "name": "pengzhanbo",
    "email": "volodymyr@foxmail.com",
    "url": "https://github.com/pengzhanbo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "tools/tools/shiki-twoslash"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": [
    "./lib/client/styles/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./lib/node/index.d.ts",
      "default": "./lib/node/index.js"
    },
    "./client": {
      "types": "./lib/client/index.d.ts",
      "default": "./lib/client/index.js"
    },
    "./twoslash.css": "./lib/client/styles/twoslash.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config-loader unrun",
    "clean": "rimraf --glob ./lib",
    "style": "sass src:lib --embed-sources --style=compressed --pkg-importer=node"
  },
  "dependencies": {
    "@shikijs/twoslash": "^4.0.1",
    "@vuepress/helper": "workspace:*",
    "floating-vue": "^5.2.2",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "twoslash": "^0.3.6",
    "twoslash-vue": "^0.3.6",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@types/hast": "^3.0.4",
    "shiki": "^4.0.1",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vuepress": "catalog:"
  }
}
